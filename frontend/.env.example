# ============================================
# PLANTILLA DE CONFIGURACIÓN - FRONTEND
# Copia este archivo a .env
# ============================================

# --- API BACKEND ---
# URL base del backend (Django/DRF).
# Si se deja vacio en desarrollo, se arma automaticamente como:
#   http(s)://<host-del-navegador>:<VITE_BACKEND_PORT>/api/v1
VITE_API_URL=
VITE_BACKEND_PORT=5000
VITE_API_TIMEOUT=30000

# Proxy de Vite (solo aplica si usas /api y /ws relativos)
VITE_DEV_PROXY_TARGET=http://localhost:5000

# --- REALTIME / WEBSOCKETS ---
# Ruta por defecto para WebSocket (usa mismo host/puerto del frontend)
VITE_VISITS_STREAM_PATH=/ws/v1/visits/stream

# Override opcional para usar URL absoluta de WebSocket.
# Acepta ws://, wss://, http://, https:// o //host:port/path
# VITE_VISITS_STREAM_URL=

# --- METADATA APP ---
VITE_APP_NAME=SIRES
VITE_APP_VERSION=1.0.0

# --- ENTORNO ---
# Opciones: development | production
VITE_ENV=development

# --- FEATURES FLAGS ---
# Interruptores para habilitar/deshabilitar funciones
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true

# --- MOCK MODE ---
# Set to "true" to use mock API instead of real backend
VITE_USE_MSW=false
