{
  "name": "sires-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/patch-vite-proxy-bun-compat.ts && vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test src/test/e2e/flujo-clinico/flujo-clinico-smoke.e2e.ts --config=playwright.smoke.docker.config.mjs --project=chromium",
    "test:e2e:kan4": "playwright test src/test/e2e/flujo-clinico/flujo-clinico-smoke.e2e.ts src/test/e2e/flujo-clinico/flujo-clinico-excepciones.e2e.ts --config=playwright.smoke.docker.config.mjs --project=chromium --max-failures=1",
    "quality:kan4:smoke": "bun run test:run src/test/integration/flujo-clinico/RecepcionQueuePage.ui.test.tsx src/test/integration/flujo-clinico/SomatometriaCapturePage.ui.test.tsx src/test/integration/flujo-clinico/DoctorConsultationPage.ui.test.tsx src/test/integration/flujo-clinico/CaptureVitals.api.test.ts src/test/integration/flujo-clinico/useVisitRealtimeSync.test.tsx && bun run test:e2e:smoke",
    "quality:kan4:release": "bun run test:run src/test/integration/flujo-clinico/RecepcionQueuePage.ui.test.tsx src/test/integration/flujo-clinico/SomatometriaCapturePage.ui.test.tsx src/test/integration/flujo-clinico/DoctorConsultationPage.ui.test.tsx src/test/integration/flujo-clinico/CaptureVitals.api.test.ts src/test/integration/flujo-clinico/useVisitRealtimeSync.test.tsx && bun run test:e2e:kan4"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.90.2",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.562.0",
    "react": "^19.2.1",
    "react-day-picker": "^9.5.0",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.66.1",
    "react-router-dom": "^7.9.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@faker-js/faker": "^10.2.0",
    "@mswjs/data": "^0.16.2",
    "@playwright/test": "^1.57.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^24.10.1",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "nprogress": "^0.2.0",
    "playwright": "^1.57.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "7.2.2",
    "vitest": "^4.0.16"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
