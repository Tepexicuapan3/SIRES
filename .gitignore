# Dependencies
node_modules/
*/node_modules/
__pycache__/
*/__pycache__/
*.pyc
*.pyo
*.pyd
venv/
*/venv/
env/
*/env/
envdevelopment/
*/envdevelopment/

# Environment variables
# Ignorar archivos .env activos
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# PERMITIR subir los templates
!**/.env.example
!**/.env.development
!**/.env.production

