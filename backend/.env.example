# Archivo opcional para ejecutar backend fuera de Docker.
# En docker-first, usar la configuracion centralizada en .env (raiz del repo).

DEBUG=true
SECRET_KEY=change-me-in-production
ALLOW_ALL_HOSTS=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WS_ALLOW_ALL_ORIGINS=false
WS_ALLOWED_ORIGINS=

DB_ENGINE=django.db.backends.mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sires
DB_USER=sires
DB_PASSWORD=sires_dev_password
CHANNEL_REDIS_URL=redis://localhost:6379/1
RUN_SEED_ON_BOOT=true

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=
EMAIL_TIMEOUT=10
