# ============================================
# BACKEND (Django/DRF) - Variables de entorno
# Copia este archivo a backend/.env
# ============================================

# --- Core Django ---
# En desarrollo puedes dejar DEBUG=True.
DEBUG=True

# Clave de Django para firma de tokens/sesiones.
# Produccion: generar una clave fuerte unica.
SECRET_KEY=change-me-with-a-strong-secret-key

# Desarrollo LAN: true permite cualquier host (ignora ALLOWED_HOSTS).
ALLOW_ALL_HOSTS=True

# Hosts permitidos por Django, separados por coma.
# En desarrollo LAN puede usarse * para evitar bloqueos por IP dinamica.
ALLOWED_HOSTS=*

# Origins permitidos para CORS, separados por coma.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Origins de confianza para CSRF (cuando aplica).
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- WebSocket ---
# true para permitir cualquier Origin (recomendado solo en desarrollo LAN)
WS_ALLOW_ALL_ORIGINS=False

# Lista opcional de Origins permitidos para WebSocket
# Si esta vacia, usa ALLOWED_HOSTS
WS_ALLOWED_ORIGINS=

# --- Base de datos (MySQL) ---
# Local (sin Docker): usa localhost.
# Docker Compose: normalmente DB_HOST=mysql.
DB_HOST=
DB_PORT=3306
DB_NAME=sires
DB_USER=sires
DB_PASSWORD=

# --- Email SMTP (opcional para recovery OTP por correo) ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=
EMAIL_TIMEOUT=10
