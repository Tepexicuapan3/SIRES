# ============================================
# SIRES - Docker-first development contract
# Copia este archivo a .env en la raiz del repo
# ============================================

# Nombre del proyecto compose (opcional)
COMPOSE_PROJECT_NAME=sires

# --- Puertos host ---
FRONTEND_PORT=5173
BACKEND_PORT=5000
AUTH_DB_PORT=5432
REDIS_PORT=6379

# --- Base de datos dominio Auth (PostgreSQL) ---
AUTH_DB_HOST=auth-db
AUTH_DB_NAME=sires_auth
AUTH_DB_USER=sires_auth
AUTH_DB_PASSWORD=sires_auth_dev_password

# --- Backend (Django) ---
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOW_ALL_HOSTS=true
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WS_ALLOW_ALL_ORIGINS=false
WS_ALLOWED_ORIGINS=
RUN_SEED_ON_BOOT=true
ALLOW_USER_CREATE_WITHOUT_EMAIL=true
RBAC_READ_S1_ENABLED=false
RBAC_ROLE_MUTATION_S2_ENABLED=false

# --- SMTP / Email ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=no-reply@sires.local
EMAIL_TIMEOUT=10
SIRES_LOGIN_URL=http://localhost:5173/login
SIRES_SUPPORT_EMAIL=soporte@sires.local

# --- Frontend (Vite) ---
# URL explicita del backend para evitar drift entre entornos.
VITE_API_URL=http://localhost:5000/api/v1
VITE_DEV_PROXY_TARGET=http://backend:5000
VITE_BACKEND_PORT=5000
VITE_VISITS_STREAM_PATH=/ws/v1/visits/stream
VITE_VISITS_STREAM_URL=
VITE_VISITS_STREAM_HEARTBEAT_INTERVAL_MS=30000
VITE_VISITS_STREAM_HEARTBEAT_TIMEOUT_MS=10000
VITE_VISITS_STREAM_BACKOFF_BASE_MS=1000
VITE_VISITS_STREAM_BACKOFF_MAX_MS=30000
VITE_VISITS_STREAM_JITTER_RATIO=0.1
VITE_VISITS_STREAM_DISCONNECT_GRACE_MS=1500
VITE_APP_NAME=SIRES
VITE_APP_VERSION=1.0.0
VITE_API_TIMEOUT=30000
VITE_USE_MSW=false
