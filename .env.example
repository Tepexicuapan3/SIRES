# ============================================
# OPENCODE MCP SERVERS - Variables de Entorno
# Copia este archivo a .env y ajusta los valores
# ============================================

# --- MySQL MCP Server ---
# Credenciales para el MCP de MySQL (queries directas desde OpenCode)
MYSQL_HOST=10.15.15.76
MYSQL_PORT=3306
MYSQL_USER=sires
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=sires

# --- Redis MCP Server ---
# Conexión a Redis para operaciones de cache/OTP desde OpenCode
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Notas ---
# Estas variables son usadas por los MCP servers configurados en opencode.json
# Los valores de MySQL deben coincidir con los de backend/.env
# Redis por defecto usa el servicio del docker-compose (expuesto en 6379)

# ============================================
# SIRES (Docker Compose) - Variables compartidas
# Cada desarrollador puede tener su propio .env en la raiz
# ============================================

# Puertos publicados en la maquina host
FRONTEND_PORT=5173
BACKEND_PORT=5000
REDIS_PORT=6379

# Host principal para abrir el frontend desde otros dispositivos
# En la maquina que levanta Docker, puede ser localhost o su IP LAN
SIRES_HOST=localhost

# API directa al backend desde el navegador.
# Si queda vacio, frontend arma automaticamente:
#   http(s)://<host-del-navegador>:<VITE_BACKEND_PORT>/api/v1
VITE_API_URL=

# Puerto del backend usado en el fallback automatico anterior.
VITE_BACKEND_PORT=5000

# Vite dev proxy (frontend -> backend)
# Solo aplica si usas rutas relativas /api y /ws.
VITE_DEV_PROXY_TARGET=http://backend:5000

# Realtime/WebSocket
# Con API directa, el frontend deriva ws:// o wss:// automaticamente.
VITE_VISITS_STREAM_PATH=/ws/v1/visits/stream

# Override opcional con URL absoluta (vaciar para usar la ruta relativa)
VITE_VISITS_STREAM_URL=

# Estabilidad/reconexion websocket
VITE_VISITS_STREAM_HEARTBEAT_INTERVAL_MS=30000
VITE_VISITS_STREAM_HEARTBEAT_TIMEOUT_MS=10000
VITE_VISITS_STREAM_BACKOFF_BASE_MS=1000
VITE_VISITS_STREAM_BACKOFF_MAX_MS=30000
VITE_VISITS_STREAM_JITTER_RATIO=0.1
VITE_VISITS_STREAM_DISCONNECT_GRACE_MS=1500

# Backend seguridad/origenes (solo entorno local)
# true ignora ALLOWED_HOSTS y permite cualquier host (LAN/dev)
ALLOW_ALL_HOSTS=true

# En Docker dev conviene usar * para soportar acceso por LAN sin friccion.
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# WebSocket Origin policy
# true permite conexiones websocket desde cualquier Origin (LAN/dev)
WS_ALLOW_ALL_ORIGINS=true

# Lista opcional si queres endurecer origins websocket
WS_ALLOWED_ORIGINS=
