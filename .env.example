# ============================================
# SIRES - Docker-first development contract
# Copia este archivo a .env en la raiz del repo
# ============================================

# Nombre del proyecto compose (opcional)
COMPOSE_PROJECT_NAME=sires

# --- Puertos host ---
FRONTEND_PORT=5173
BACKEND_PORT=5000
MYSQL_PORT=3306
REDIS_PORT=6379

# --- Base de datos (MySQL) ---
MYSQL_DATABASE=sires
MYSQL_USER=sires
MYSQL_PASSWORD=sires_dev_password
MYSQL_ROOT_PASSWORD=sires_root_dev_password

# --- Backend (Django) ---
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOW_ALL_HOSTS=true
DB_ENGINE=django.db.backends.mysql
DJANGO_ALLOWED_HOSTS=*
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WS_ALLOW_ALL_ORIGINS=false
WS_ALLOWED_ORIGINS=
RUN_SEED_ON_BOOT=true

# --- Frontend (Vite) ---
# Si VITE_API_URL queda vacio, el frontend usa /api/v1 con proxy de Vite.
VITE_API_URL=
VITE_DEV_PROXY_TARGET=http://backend:5000
VITE_BACKEND_PORT=5000
VITE_VISITS_STREAM_PATH=/ws/v1/visits/stream
VITE_VISITS_STREAM_URL=
VITE_VISITS_STREAM_HEARTBEAT_INTERVAL_MS=30000
VITE_VISITS_STREAM_HEARTBEAT_TIMEOUT_MS=10000
VITE_VISITS_STREAM_BACKOFF_BASE_MS=1000
VITE_VISITS_STREAM_BACKOFF_MAX_MS=30000
VITE_VISITS_STREAM_JITTER_RATIO=0.1
VITE_VISITS_STREAM_DISCONNECT_GRACE_MS=1500
VITE_APP_NAME=SIRES
VITE_APP_VERSION=1.0.0
VITE_API_TIMEOUT=30000
VITE_USE_MSW=false
